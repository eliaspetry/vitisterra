---
import { RegisterForm } from "./RegisterForm"
---
<section id="signup">
    <div class="px-5 pb-10 flex flex-col items-center justify-center w-full">
        <div class="w-full max-w-7xl grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="flex flex-col items-center justify-center">
                <RegisterForm client:load></RegisterForm>
            </div>
            <div class="flex flex-col items-center">
                <picture>
                    <source
                        media="(min-width: 768px)"
                        srcset="gallery/drinking-wine.webp"
                        type="image/webp"
                    />
                    <img
                        src="gallery/drinking-wine-mobile.webp"
                        alt="hombre catando vino"
                        class="w-full md:w-lg"
                    />
                </picture>
            </div>
        </div>
    </div>
</section>